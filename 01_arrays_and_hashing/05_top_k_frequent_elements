# Top K Frequent Elements
# Difficulty: Medium
# https://neetcode.io/problems/top-k-elements-in-list/question

class Solution:
    def topKFrequent(self, nums: List[int], k: int) -> List[int]:
        # Bucket sort: each number in the array appears a certain number of times
        # The maximum possbile frequency is the array's length itself.
        # All numbers that appear x times go to group freq[x] 
        # Agter group building, we llok from the highest possible one down to the lowest,
        # and collect numbers from this group until we have k of them.

        # nums = [1, 1, 1, 2, 2, 100], k = 2

        # Keys: numbers, Values:frequencies
        count = {}  # {1: 3, 2: 2, 100: 1}
        # Keys: frequencies, Values: numbers with that frequency
        freq = [[] for i in range(len(nums)+1)]  # len() = 6

        for n in nums:
            count[n] = 1 + count.get(n, 0)
        
        for n, c in count.items():
            freq[c].append(n) # [ [], [100], [2], [1], [], [], [] ]

        res = []
        for i in range(len(freq)-1 ,0, -1):
            for n in freq[i]:
                res.append(n)
                if len(res) == k:
                    return res

        # O(n), instead of using f.e. bubble/merge sorting O(nlong)  
