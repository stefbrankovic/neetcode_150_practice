# Contains Duplicate
# Difficulty: Easy
# https://neetcode.io/problems/duplicate-integer/question?list=neetcode150

class Solution:
    # Using the Hashset strucutre to store all unique values
    def hasDuplicate(self, nums: List[int]) -> bool:
        unique = set()
        for n in nums:
            if n in unique:
                return True
            unique.add(n)
        return False      
